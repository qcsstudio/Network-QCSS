{
  "name": "network-qcss",
  "version": "1.0.0",
  "private": true,
  "description": "Robust Next.js product for network services, cybersecurity lead generation, diagnostic tools, automation, and admin intelligence.",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "env:check": "node scripts/check-env.mjs",
    "deploy:check": "npm run env:check && npm run prisma:generate && npm run typecheck && npm run build",
    "smoke": "node scripts/smoke.mjs",
    "site:qa": "node scripts/site-qa.mjs",
    "test:verifygrid": "node --experimental-strip-types --test tests/verifygrid-domain.test.mjs",
    "content:seed": "node scripts/seed-content-studio.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "csv-parse": "^7.0.1",
    "fast-xml-parser": "^5.10.1",
    "lucide-react": "^0.560.0",
    "next": "16.2.11",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.11",
    "prisma": "7.8.0",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "@hono/node-server": "^2.0.5",
    "postcss": "^8.5.10",
    "sharp": "^0.35.0"
  }
}
