# Razorpay Checkout public key id. Safe to expose to the browser.
# Use the same Key Id value for NEXT_PUBLIC_RAZORPAY_KEY_ID and RAZORPAY_KEY_ID.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_or_live_xxxxxxxxxxxxxx

# Razorpay server-side credentials. Never expose or commit the secret.
RAZORPAY_KEY_ID=rzp_test_or_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret

# Optional: override or extend service pricing in paise.
PAYMENT_SERVICE_CATALOG_JSON={"profile-rewrite-100-score":{"label":"LinkedIn Profile Rewrite to 100% QCS Score","amountInPaise":4900}}

# Optional: comma-separated Razorpay Dashboard offer ids, for example offer_abc123,offer_def456.
RAZORPAY_DEFAULT_OFFER_IDS=

# Optional: QCS-managed coupons and Razorpay Dashboard offers.
# Built-in testing coupon: QCS100 gives a 100% discount and skips Razorpay checkout for this service.
RAZORPAY_COUPONS_JSON={"QCS10":{"active":true,"label":"10% launch discount","type":"percentage","value":10,"maxDiscountPaise":500,"startsAt":"2026-05-10T00:00:00+05:30","expiresAt":"2026-06-10T23:59:59+05:30","serviceKeys":["profile-rewrite-100-score"]},"QCS100":{"active":true,"label":"100% testing discount","type":"percentage","value":100,"allowFreeCheckout":true,"serviceKeys":["profile-rewrite-100-score"]}}

# Required for paid AI-enhanced profile rewrites. Server-side only.
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_REWRITE_MODEL=gpt-4.1-mini
