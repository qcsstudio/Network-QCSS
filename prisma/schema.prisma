generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  interest      String
  challenge     String?
  pipeline      String
  score         Int      @default(0)
  priority      String
  stage         String   @default("new")
  sessionId     String?
  country       String?
  ipHash        String?
  attribution   Json?
  consent       Json?
  sourceProfile Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([pipeline])
  @@index([priority])
  @@index([createdAt])
}

model InteractionEvent {
  id        String   @id @default(cuid())
  name      String
  sessionId String?
  metadata  Json?
  consent   Json?
  country   String?
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([name])
  @@index([createdAt])
}

model Assessment {
  id             String   @id @default(cuid())
  tool           String
  title          String
  pipeline       String
  recommendation String
  riskLevel      String
  score          Int
  answers        Json?
  sessionId      String?
  attribution    Json?
  consent        Json?
  country        String?
  ipHash         String?
  createdAt      DateTime @default(now())

  @@index([tool])
  @@index([pipeline])
  @@index([createdAt])
}

model ResourceDownload {
  id          String   @id @default(cuid())
  resource    String
  sessionId   String?
  attribution Json?
  consent     Json?
  country     String?
  ipHash      String?
  createdAt   DateTime @default(now())

  @@index([resource])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  actor     String?
  target    String?
  metadata  Json?
  country   String?
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([actor])
  @@index([createdAt])
}

model ContentPost {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  status      String            @default("draft")
  content     Json
  sourceUrl   String?
  createdBy   String?
  approvedBy  String?
  approvedAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  revisions   ContentRevision[]
  approvals   ContentApproval[]

  @@index([status])
  @@index([publishedAt])
  @@index([updatedAt])
}

model ContentApproval {
  id                String      @id @default(cuid())
  postId            String
  revisionVersion   Int
  revisionHash      String
  status            String      @default("pending")
  publishToLinkedIn Boolean     @default(true)
  actionTokenHash   String      @unique
  whatsappMessageId String?
  requestedAt       DateTime    @default(now())
  expiresAt         DateTime
  decidedAt         DateTime?
  decidedBy         String?
  feedback          String?
  post              ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, status])
  @@index([status, expiresAt])
}

model IntegrationConnection {
  id                   String   @id @default(cuid())
  provider             String   @unique
  accountId            String
  accountName          String
  encryptedAccessToken String
  scope                String
  expiresAt            DateTime
  status               String   @default("connected")
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([provider, status])
  @@index([expiresAt])
}

model SocialPublication {
  id              String    @id @default(cuid())
  channel         String
  contentType     String
  contentId       String
  contentRevision String
  status          String    @default("queued")
  sourceUrl       String
  commentary      String
  imageUrl        String?
  externalId      String?
  attempts        Int       @default(0)
  nextAttemptAt   DateTime  @default(now())
  lastAttemptAt   DateTime?
  lastError       String?
  publishedAt     DateTime?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([channel, contentType, contentId, contentRevision])
  @@index([channel, status, nextAttemptAt])
  @@index([contentType, contentId])
}

model AdvisorySource {
  id                  String             @id @default(cuid())
  slug                String             @unique
  name                String
  vendor              String
  format              String
  url                 String
  officialHost        String
  enabled             Boolean            @default(true)
  priority            Int                @default(50)
  etag                String?
  lastModified        String?
  lastSuccessAt       DateTime?
  lastCheckedAt       DateTime?
  lastError           String?
  consecutiveFailures Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  advisories          SecurityAdvisory[]

  @@index([enabled, priority])
  @@index([lastSuccessAt])
}

model SecurityAdvisory {
  id                 String                     @id @default(cuid())
  sourceId           String
  externalId         String
  slug               String                     @unique
  title              String
  vendor             String
  summary            String
  severity           String
  cvssScore          Float?
  priorityScore      Int
  cves               Json
  products           Json
  affectedVersions   Json
  fixedVersions      Json
  remediation        String
  workaround         String?
  exploitationStatus String
  sourceUrl          String
  contentHash        String
  status             String                     @default("published")
  editorialOverride  Boolean                    @default(false)
  createdBy          String?
  updatedBy          String?
  deletedAt          DateTime?
  vendorPublishedAt  DateTime
  vendorUpdatedAt    DateTime
  firstSeenAt        DateTime                   @default(now())
  lastVerifiedAt     DateTime                   @default(now())
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  source             AdvisorySource             @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  revisions          SecurityAdvisoryRevision[]

  @@unique([sourceId, externalId])
  @@index([status, vendorPublishedAt])
  @@index([severity, priorityScore])
  @@index([vendor])
  @@index([editorialOverride, status])
}

model SecurityAdvisoryRevision {
  id          String           @id @default(cuid())
  advisoryId  String
  version     Int
  contentHash String
  changes     Json?
  payload     Json
  createdAt   DateTime         @default(now())
  advisory    SecurityAdvisory @relation(fields: [advisoryId], references: [id], onDelete: Cascade)

  @@unique([advisoryId, version])
  @@index([advisoryId, createdAt])
}

model ContentRevision {
  id        String      @id @default(cuid())
  postId    String
  version   Int
  action    String
  actor     String?
  content   Json
  createdAt DateTime    @default(now())
  post      ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, version])
  @@index([postId, createdAt])
}

model VerifyGridWorkspace {
  id                  String                       @id @default(cuid())
  slug                String                       @unique
  name                String
  legalName           String?
  primaryContactName  String
  primaryContactEmail String
  countryCode         String?
  timezone            String                       @default("Asia/Kolkata")
  status              String                       @default("active")
  createdBy           String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  engagements         VerifyGridEngagement[]
  assets              VerifyGridAsset[]
  findings            VerifyGridFinding[]
  importBatches       VerifyGridImportBatch[]
  observations        VerifyGridObservation[]
  executionJobs       VerifyGridExecutionJob[]
  reports             VerifyGridReport[]
  connectorProfiles   VerifyGridConnectorProfile[]
  sensors             VerifyGridSensor[]
  memberships         VerifyGridMembership[]
  activities          VerifyGridActivity[]

  @@index([status, updatedAt])
  @@index([primaryContactEmail])
}

model VerifyGridEngagement {
  id                    String                       @id @default(cuid())
  workspaceId           String
  reference             String                       @unique
  title                 String
  serviceType           String
  status                String                       @default("draft")
  testMode              String                       @default("safe_checks")
  riskTier              String                       @default("standard")
  scopeSummary          String
  rulesOfEngagement     Json?
  plannedStartAt        DateTime?
  plannedEndAt          DateTime?
  emergencyContactName  String
  emergencyContactEmail String
  emergencyContactPhone String?
  createdBy             String?
  updatedBy             String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  workspace             VerifyGridWorkspace          @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  scopeTargets          VerifyGridScopeTarget[]
  authorizations        VerifyGridAuthorization[]
  assets                VerifyGridAsset[]
  findings              VerifyGridFinding[]
  importBatches         VerifyGridImportBatch[]
  observations          VerifyGridObservation[]
  executionJobs         VerifyGridExecutionJob[]
  reports               VerifyGridReport[]
  connectorProfiles     VerifyGridConnectorProfile[]
  connectorRuns         VerifyGridConnectorRun[]
  activities            VerifyGridActivity[]

  @@index([workspaceId, status])
  @@index([status, plannedStartAt])
  @@index([updatedAt])
}

model VerifyGridScopeTarget {
  id                 String               @id @default(cuid())
  engagementId       String
  targetType         String
  value              String
  environment        String               @default("production")
  criticality        String               @default("medium")
  permission         String               @default("safe_checks")
  inScope            Boolean              @default(true)
  ownershipConfirmed Boolean              @default(false)
  notes              String?
  createdBy          String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  engagement         VerifyGridEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([engagementId, targetType, value])
  @@index([engagementId, inScope])
}

model VerifyGridAuthorization {
  id                 String                   @id @default(cuid())
  engagementId       String
  status             String                   @default("active")
  scopeHash          String
  approvedByName     String
  approvedByEmail    String
  approvedByTitle    String?
  authorityConfirmed Boolean                  @default(false)
  approvalMethod     String                   @default("recorded_admin")
  validFrom          DateTime
  validUntil         DateTime
  artifactUrl        String?
  artifactSha256     String?
  notes              String?
  authorizedBy       String?
  authorizedAt       DateTime                 @default(now())
  revokedAt          DateTime?
  revokedBy          String?
  revocationReason   String?
  engagement         VerifyGridEngagement     @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  executionJobs      VerifyGridExecutionJob[]

  @@index([engagementId, status, validUntil])
  @@index([scopeHash])
}

model VerifyGridAsset {
  id           String                @id @default(cuid())
  workspaceId  String
  engagementId String?
  identifier   String
  name         String
  kind         String
  environment  String                @default("production")
  criticality  String                @default("medium")
  exposure     String                @default("unknown")
  vendor       String?
  product      String?
  version      String?
  ownerName    String?
  ownerEmail   String?
  tags         Json?
  source       String                @default("manual")
  firstSeenAt  DateTime              @default(now())
  lastSeenAt   DateTime              @default(now())
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  workspace    VerifyGridWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  engagement   VerifyGridEngagement? @relation(fields: [engagementId], references: [id], onDelete: SetNull)
  findings     VerifyGridFinding[]

  @@unique([workspaceId, identifier])
  @@index([workspaceId, criticality])
  @@index([engagementId])
  @@index([lastSeenAt])
}

model VerifyGridFinding {
  id                 String                  @id @default(cuid())
  workspaceId        String
  engagementId       String
  assetId            String?
  fingerprint        String
  title              String
  description        String
  status             String                  @default("open")
  severity           String
  confidence         String                  @default("unverified")
  source             String                  @default("manual")
  sourceReference    String?
  advisoryExternalId String?
  cvssScore          Float?
  epssScore          Float?
  knownExploited     Boolean                 @default(false)
  attackPath         String?
  businessImpact     String
  evidenceSummary    String?
  remediation        String
  ownerName          String?
  ownerEmail         String?
  dueAt              DateTime?
  firstDetectedAt    DateTime                @default(now())
  lastObservedAt     DateTime                @default(now())
  resolvedAt         DateTime?
  createdBy          String?
  updatedBy          String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  workspace          VerifyGridWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  engagement         VerifyGridEngagement    @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  asset              VerifyGridAsset?        @relation(fields: [assetId], references: [id], onDelete: SetNull)
  evidence           VerifyGridEvidence[]
  retests            VerifyGridRetest[]
  observations       VerifyGridObservation[]
  activities         VerifyGridActivity[]

  @@unique([workspaceId, fingerprint])
  @@index([engagementId, status, severity])
  @@index([workspaceId, knownExploited])
  @@index([assetId])
  @@index([dueAt])
}

model VerifyGridEvidence {
  id             String            @id @default(cuid())
  findingId      String
  evidenceType   String
  title          String
  summary        String?
  objectKey      String?
  sourceUrl      String?
  sha256         String?
  classification String            @default("confidential")
  metadata       Json?
  collectedBy    String?
  collectedAt    DateTime          @default(now())
  createdAt      DateTime          @default(now())
  finding        VerifyGridFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([findingId, collectedAt])
  @@index([sha256])
}

model VerifyGridRetest {
  id              String            @id @default(cuid())
  findingId       String
  status          String            @default("requested")
  requestedBy     String?
  requestedAt     DateTime          @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  result          String?
  evidenceSummary String?
  performedBy     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  finding         VerifyGridFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([findingId, requestedAt])
  @@index([status, requestedAt])
}

model VerifyGridActivity {
  id           String                @id @default(cuid())
  workspaceId  String
  engagementId String?
  findingId    String?
  action       String
  actor        String?
  metadata     Json?
  createdAt    DateTime              @default(now())
  workspace    VerifyGridWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  engagement   VerifyGridEngagement? @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  finding      VerifyGridFinding?    @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([engagementId, createdAt])
  @@index([findingId, createdAt])
}

model VerifyGridImportBatch {
  id                String                  @id @default(cuid())
  workspaceId       String
  engagementId      String
  connector         String
  format            String
  status            String                  @default("processing")
  fileName          String?
  contentSha256     String
  scopeHash         String
  authorizationId   String?
  observationCount  Int                     @default(0)
  inScopeCount      Int                     @default(0)
  outOfScopeCount   Int                     @default(0)
  unmatchedCount    Int                     @default(0)
  promotedCount     Int                     @default(0)
  duplicateCount    Int                     @default(0)
  rejectedCount     Int                     @default(0)
  enrichmentStatus  String                  @default("not_requested")
  sourceStartedAt   DateTime?
  sourceCompletedAt DateTime?
  summary           Json?
  errorMessage      String?
  importedBy        String?
  createdAt         DateTime                @default(now())
  completedAt       DateTime?
  workspace         VerifyGridWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  engagement        VerifyGridEngagement    @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  observations      VerifyGridObservation[]

  @@unique([engagementId, connector, contentSha256])
  @@index([workspaceId, createdAt])
  @@index([engagementId, status, createdAt])
}

model VerifyGridObservation {
  id                 String                @id @default(cuid())
  batchId            String
  workspaceId        String
  engagementId       String
  promotedFindingId  String?
  fingerprint        String
  assetIdentifier    String
  assetName          String
  assetKind          String                @default("host")
  environment        String                @default("production")
  assetCriticality   String                @default("medium")
  title              String
  description        String
  severity           String
  confidence         String                @default("unverified")
  sourceReference    String?
  advisoryExternalId String?
  cvssScore          Float?
  epssScore          Float?
  epssPercentile     Float?
  knownExploited     Boolean               @default(false)
  port               Int?
  protocol           String?
  service            String?
  evidenceSummary    String?
  remediation        String
  scopeDisposition   String                @default("unmatched")
  scopeTargetId      String?
  dispositionReason  String?
  promotionStatus    String                @default("pending")
  rawMetadata        Json?
  firstObservedAt    DateTime?
  lastObservedAt     DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  batch              VerifyGridImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  workspace          VerifyGridWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  engagement         VerifyGridEngagement  @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  promotedFinding    VerifyGridFinding?    @relation(fields: [promotedFindingId], references: [id], onDelete: SetNull)

  @@unique([batchId, fingerprint])
  @@index([engagementId, scopeDisposition, promotionStatus])
  @@index([workspaceId, advisoryExternalId])
  @@index([promotedFindingId])
}

model VerifyGridExecutionJob {
  id                   String                  @id @default(cuid())
  workspaceId          String
  engagementId         String
  authorizationId      String
  capability           String
  capabilityLevel      String
  status               String                  @default("validated")
  scopeHash            String
  targetIds            Json
  targetSnapshot       Json
  rationale            String
  requestedStartAt     DateTime
  validUntil           DateTime
  maxRequestsPerSecond Int
  manifest             Json
  manifestSha256       String
  dispatchStatus       String                  @default("worker_not_connected")
  sensorId             String?
  attempt              Int                     @default(0)
  maxAttempts          Int                     @default(3)
  queuedAt             DateTime?
  claimedAt            DateTime?
  leaseUntil           DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  resultBatchId        String?
  resultSummary        Json?
  lastError            String?
  requestedBy          String?
  cancelledBy          String?
  cancelledAt          DateTime?
  cancellationReason   String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  workspace            VerifyGridWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  engagement           VerifyGridEngagement    @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  authorization        VerifyGridAuthorization @relation(fields: [authorizationId], references: [id], onDelete: Restrict)
  sensor               VerifyGridSensor?       @relation(fields: [sensorId], references: [id], onDelete: SetNull)

  @@index([engagementId, status, requestedStartAt])
  @@index([authorizationId])
  @@index([sensorId, status, requestedStartAt])
  @@index([dispatchStatus, leaseUntil])
  @@index([manifestSha256])
}

model VerifyGridReport {
  id             String               @id @default(cuid())
  workspaceId    String
  engagementId   String
  version        Int
  reportType     String
  status         String               @default("final")
  title          String
  scopeHash      String
  snapshot       Json
  snapshotSha256 String
  generatedBy    String?
  generatedAt    DateTime             @default(now())
  workspace      VerifyGridWorkspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  engagement     VerifyGridEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([engagementId, reportType, version])
  @@index([workspaceId, generatedAt])
  @@index([engagementId, generatedAt])
  @@index([snapshotSha256])
}

model VerifyGridConnectorProfile {
  id                  String                   @id @default(cuid())
  workspaceId         String
  engagementId        String?
  provider            String
  label               String
  status              String                   @default("active")
  baseUrl             String
  credentialRef       String
  syncMode            String                   @default("differential")
  scheduleMinutes     Int                      @default(1440)
  settings            Json?
  cursor              Json?
  lastSyncAt          DateTime?
  nextSyncAt          DateTime                 @default(now())
  lastSuccessAt       DateTime?
  consecutiveFailures Int                      @default(0)
  lastError           String?
  createdBy           String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  workspace           VerifyGridWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  engagement          VerifyGridEngagement?    @relation(fields: [engagementId], references: [id], onDelete: SetNull)
  runs                VerifyGridConnectorRun[]

  @@unique([workspaceId, label])
  @@index([status, nextSyncAt])
  @@index([workspaceId, provider])
  @@index([engagementId])
}

model VerifyGridConnectorRun {
  id             String                     @id @default(cuid())
  connectorId    String
  engagementId   String
  status         String                     @default("queued")
  trigger        String                     @default("scheduled")
  attempt        Int                        @default(0)
  maxAttempts    Int                        @default(5)
  nextAttemptAt  DateTime                   @default(now())
  leaseTokenHash String?
  leaseUntil     DateTime?
  remoteJobId    String?
  cursorBefore   Json?
  cursorAfter    Json?
  summary        Json?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdBy      String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  connector      VerifyGridConnectorProfile @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  engagement     VerifyGridEngagement       @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([connectorId, createdAt])
  @@index([engagementId, createdAt])
}

model VerifyGridSensor {
  id            String                   @id @default(cuid())
  workspaceId   String
  name          String
  status        String                   @default("active")
  tokenHash     String                   @unique
  tokenLastFour String
  capabilities  Json
  version       String?
  region        String?
  lastSeenAt    DateTime?
  createdBy     String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  revokedAt     DateTime?
  revokedBy     String?
  workspace     VerifyGridWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executionJobs VerifyGridExecutionJob[]

  @@unique([workspaceId, name])
  @@index([workspaceId, status])
  @@index([lastSeenAt])
}

model VerifyGridMembership {
  id           String                  @id @default(cuid())
  workspaceId  String
  email        String
  displayName  String?
  role         String                  @default("client_viewer")
  status       String                  @default("invited")
  invitedBy    String?
  invitedAt    DateTime                @default(now())
  acceptedAt   DateTime?
  lastAccessAt DateTime?
  revokedAt    DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  workspace    VerifyGridWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accessTokens VerifyGridAccessToken[]

  @@unique([workspaceId, email])
  @@index([email, status])
  @@index([workspaceId, role, status])
}

model VerifyGridAccessToken {
  id           String               @id @default(cuid())
  membershipId String
  tokenHash    String               @unique
  purpose      String               @default("portal_access")
  expiresAt    DateTime
  usedAt       DateTime?
  revokedAt    DateTime?
  createdBy    String?
  createdAt    DateTime             @default(now())
  membership   VerifyGridMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId, expiresAt])
  @@index([expiresAt, usedAt])
}

model VerifyGridOnboardingRequest {
  id                    String                      @id @default(cuid())
  email                 String
  displayName           String
  organizationName      String
  legalName             String?
  phone                 String
  countryCode           String?
  timezone              String                      @default("UTC")
  serviceType           String
  scopeSummary          String
  requestedStartAt      DateTime?
  emergencyContactName  String
  emergencyContactEmail String
  status                String                      @default("pending_email")
  contactConsentAt      DateTime
  emailVerifiedAt       DateTime?
  workspaceId           String?
  engagementId          String?
  membershipId          String?
  reviewedBy            String?
  reviewedAt            DateTime?
  reviewNote            String?
  sourceCountry         String?
  sourceIpHash          String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  verificationTokens    VerifyGridOnboardingToken[]

  @@index([status, createdAt])
  @@index([email, status])
  @@index([organizationName, status])
}

model VerifyGridOnboardingToken {
  id          String                      @id
  requestId   String
  tokenHash   String                      @unique
  expiresAt   DateTime
  usedAt      DateTime?
  revokedAt   DateTime?
  createdAt   DateTime                    @default(now())
  request     VerifyGridOnboardingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, expiresAt])
  @@index([expiresAt, usedAt])
}
